# Meta WhatsApp Business API
WHATSAPP_TOKEN=your_whatsapp_token_here
PHONE_NUMBER_ID=your_phone_number_id_here
VERIFY_TOKEN=realstate_webhook_token
NOTIFY_NUMBER=5491123485638

# DeepSeek AI
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Google Sheets
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Cache TTL for sheet data (seconds)
SHEET_CACHE_TTL=300

# Google Calendar
GOOGLE_CALENDAR_ID=your_calendar_id_here

# Facebook / Instagram Messenger
PAGE_ACCESS_TOKEN=your_page_access_token_here

# Analytics dashboard
ANALYTICS_DB_PATH=/data/analytics.db
DASHBOARD_TOKEN=your_secret_dashboard_token_here
DASHBOARD_PLAN=starter

# Branch name (optional, for multi-branch Premium)
BRANCH_NAME=
